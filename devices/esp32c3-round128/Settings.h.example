// Copy to Settings.h, then: .\scripts\sync-device.ps1 esp32c3-round128
//
// Arduino IDE (ESP32C3 Dev Module):
//   USB CDC On Boot = Enabled
//   Partition Scheme = Huge APP (3MB No OTA/1MB SPIFFS)  — required (~1.3 MB sketch)

#ifndef SETTINGS_H
#define SETTINGS_H

extern char *DUCO_USER = "your_username";
extern char *MINER_KEY = "None";
extern char *RIG_IDENTIFIER = "None";
extern const char SSID[] = "your_wifi_ssid";
extern const char PASSWORD[] = "your_wifi_password";

// Uncomment to skip hard-coded WiFi/credentials — board opens AP "Duino-Coin" on first boot
// (same as pre-built release firmware)
// #define CAPTIVE_PORTAL

#define SERIAL_PRINTING
#define SERIAL_BAUDRATE 115200
#define LWD_TIMEOUT 30000

#define DISPLAY_GC9A01
#define TOUCH_CST816D

#undef LED_BLINKING


#define BLINK_SETUP_COMPLETE 2
#define BLINK_CLIENT_CONNECT 5

#define SOFTWARE_VERSION "4.3"
extern unsigned int hashrate = 0;
extern unsigned int hashrate_core_two = 0;
extern unsigned int difficulty = 0;
extern unsigned long share_count = 0;
extern unsigned long accepted_share_count = 0;
extern String node_id = "";
extern String WALLET_ID = "";
extern unsigned int ping = 0;

#if defined(DISPLAY_GC9A01)
    #include <TFT_eSPI.h>
    TFT_eSPI tft = TFT_eSPI();
#endif

#if defined(TOUCH_CST816D)
    #include "CST816D.h"
    CST816D touch(4, 5, 1, 0);
    void display_input_poll();
#endif

IPAddress DNS_SERVER(1, 1, 1, 1);

#endif